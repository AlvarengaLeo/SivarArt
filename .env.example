# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-only — NUNCA exponer al cliente

# ── Wompi SV (pasarela de pagos) ─────────────────────────
# Docs: https://docs.wompi.sv  (+ https://docs.wompi.sv/llms.txt)
WOMPI_ENV=sandbox                     # sandbox | production
WOMPI_APP_ID=
WOMPI_API_SECRET=
WOMPI_WEBHOOK_SECRET=                 # secreto para validar el hash del webhook

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DEFAULT_LOCALE=es
PLATFORM_COMMISSION_BPS=1500          # comisión de plataforma (15%)
